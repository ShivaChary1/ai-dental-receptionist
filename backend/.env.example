GOOGLE_API_KEY=your_google_ai_studio_key
MONGODB_URI=mongodb://localhost:27017
DB_NAME=dental_ai

# Optional overrides (defaults shown)
# LLM_MODEL=gemini-2.5-flash-lite
# EMBED_MODEL=models/gemini-embedding-001
# CLINIC_NAME=SmileCare Dental Hospital

# --- Auth (JWT) ---
JWT_SECRET=change-me-to-a-long-random-string
# JWT_ALG=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Admin login (single account) ---
ADMIN_EMAIL=admin@smilecare.com
ADMIN_PASSWORD=change-me

# --- OTP ---
# OTP_TTL_SECONDS=300
# OTP_LENGTH=6

# --- WhatsApp (Meta Cloud API) — placeholders; fill in to enable live sending ---
WHATSAPP_VERIFY_TOKEN=my-webhook-verify-token
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_API_VERSION=v21.0
