# Backend API origin
VITE_API_BASE_URL=http://localhost:8000

# Public site origin used for canonical/OG URLs
VITE_PUBLIC_ORIGIN=http://localhost:5173

# Google Identity Services OAuth client id — enables "Continue with Google".
# Create one at https://console.cloud.google.com/apis/credentials (Web application,
# add your origins to Authorized JavaScript origins). Backend needs the same value
# as GOOGLE_CLIENT_ID in backend/.env.
VITE_GOOGLE_CLIENT_ID=

# PostHog project API key — enables funnel analytics. Leave empty to disable.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
